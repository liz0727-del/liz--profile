{
    "headers": [
        {
            "source": "/pdfs/(.*)",
            "headers": [
                {
                    "key": "Content-Disposition",
                    "value": "inline"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/((?!pdfs/).*)",
            "destination": "/"
        }
    ]
}